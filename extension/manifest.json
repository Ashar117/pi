{
  "manifest_version": 3,
  "name": "Pi",
  "version": "1.0.0",
  "description": "Pi agent in your browser — side panel + ask about page.",
  "permissions": ["sidePanel", "contextMenus", "activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:7712/*"],
  "background": { "service_worker": "sw.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": { "default_title": "Open Pi" }
}
