# ─────────────────────────────────────────────────────────────────────────────
# Pi .gitignore — PUBLIC repo model.
# Code is open; the identity prompts, architecture rationale, and private layers
# stay off the remote. Never commit the items below, even to a private remote.
# ─────────────────────────────────────────────────────────────────────────────

# API keys & credentials — NEVER track
.env
.env.local
*.env
app/config.py
.mcp.json
pi_dna.txt

# Identity prompts — the recipe; never expose publicly
prompts/

# Architecture internals — design rationale, honest audit
docs/adr/
docs/PROJECT_MAP.md

# God-mode private layer — strongest boundary, never track
prompts/god_consciousness.txt
prompts/god_*.txt
agent/god.py
data/god_memory.db
tickets/god/
vault/.god/

# Session data and local logs (machine-local, not source)
data/
logs/
evolution.jsonl

# Vault private tiers (Obsidian working data)
vault/memory/
vault/notes/per-ticket/

# Local LLM model weights
local_models/

# Analysis scratch — keep private
analysis/

# Cache and temp
__pycache__/
*.pyc
*.cache
.pytest_cache/
pi_env/
*.backup.*
temp_exec.py

# Obsidian config
.obsidian/

# OS and IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Obsidian vault data — private working knowledge, kept out of git entirely (T-158)
vault/

# Regenerable passive-skill reports
reports/

# God-mode migration tooling (god boundary)
scripts/migrate_god_memory.py
