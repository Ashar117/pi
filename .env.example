# Pi — environment variable template
# Copy to .env and fill in real values. .env is gitignored.

# === Required ===

# Anthropic — root mode (Claude Sonnet 4.6) and research mode
ANTHROPIC_API_KEY=sk-ant-...

# Groq — normie mode (Llama 3.3 70B) and research mode
GROQ_API_KEY=gsk_...

# Supabase — durable memory backend (l3_active_memory, organized_memory, raw_wiki)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# === Optional ===

# Gemini — research mode third agent. If absent, debate falls back to Claude + Groq only.
GEMINI_API_KEY=

# === Reserved (read by app/config.py but not currently wired) ===

# OpenWeather — placeholder for future weather tool
OPENWEATHER_API_KEY=

# Database URL — placeholder for future direct Postgres connection (currently unused)
DATABASE_URL=
