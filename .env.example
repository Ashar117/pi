# Pi — environment variable template
# Copy to .env and fill in real values.  .env is gitignored.
#
# Legend:
#   [REQUIRED]  Pi will not start without this
#   [OPTIONAL]  Feature degrades gracefully if absent
#   [FREE]      No API key needed — public endpoint used automatically
#   [RESERVED]  Parsed by config.py, not yet wired to active code

# ─────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────

# Anthropic — root mode (Claude Sonnet 4.6) + research mode debate
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Groq — normie mode (Llama 3.3 70B), session summary, L1->L2 distillation
# Get key: https://console.groq.com/  (free tier available)
GROQ_API_KEY=gsk_...

# Supabase — durable memory backend
#   Tables: l3_active_memory, organized_memory, raw_wiki
# Get from: Supabase dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Features degrade gracefully if absent
# ─────────────────────────────────────────────────────────────

# Gemini — research mode third agent (debate round 2)
# If absent, research mode runs with Claude + Groq only (2 agents instead of 3)
# Get key: https://aistudio.google.com/
GEMINI_API_KEY=

# OpenWeather — weather fallback when wttr.in is unavailable
# wttr.in is tried first (no key needed). This is only used as backup.
# Get key: https://openweathermap.org/api  (free tier: 60 calls/min)
OPENWEATHER_API_KEY=

# Obsidian Local REST API — read/write Pi's Obsidian vault
# Requires: Obsidian desktop + "Local REST API" plugin (community plugin)
# Setup: install plugin, enable HTTPS, copy API key from plugin settings
# Plugin: https://github.com/coddingtonbear/obsidian-local-rest-api
OBSIDIAN_HOST=http://127.0.0.1:27123
OBSIDIAN_API_KEY=

# ─────────────────────────────────────────────────────────────
# FREE — No key needed (public APIs used automatically)
# ─────────────────────────────────────────────────────────────
#
# These services are used by AwarenessTools at startup and need no credentials:
#   wttr.in           — current weather (geo auto-detected from IP)
#   ip-api.com        — IP geolocation (city, region, timezone)
#   BBC RSS           — global news headlines
#   hnrss.org         — Hacker News / tech news
#   Reuters RSS       — business and science news
#   hn.algolia.com    — HN front-page stories (structured JSON)
#   export.arxiv.org  — latest AI/ML/NLP research papers
#   Yahoo Finance     — live stock + crypto prices (AAPL, NVDA, BTC-USD, etc.)
#   DuckDuckGo HTML   — web_search tool (no key, no rate-limit registration)
#
# Nothing to set here — these are documented for transparency only.

# ─────────────────────────────────────────────────────────────
# RESERVED — Parsed but not yet wired to active features
# ─────────────────────────────────────────────────────────────

# Direct Postgres connection (future: bypass Supabase client for bulk ops)
DATABASE_URL=
